{
  "name": "versioned-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Versioned.AI — AI Prompt Playground & Regression Evaluation Platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:ui": "npm run dev --workspace=packages/ui",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "build:ui": "npm run build --workspace=packages/ui",
    "build:cli": "npm run build --workspace=packages/cli",
    "build": "npm run build:ui && npm run build:cli",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
